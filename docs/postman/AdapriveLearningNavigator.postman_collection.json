  "info": {
    "_postman_id": "ccf0ec4e-5c28-4a01-9b1c-bf36c340db93",
    "name": "AdapriveLearningNavigator",
    "description": "Manual API checks for ALN auth and AI-driven plan generation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const defaults = {",
          "  registerPassword: 'StrongPass123',",
          "  registerDisplayName: 'Manual Tester',",
          "  goal: 'java-backend',",
          "  goalUnknown: 'go-backend',",
          "  goalAmbiguous: 'java',",
          "  currentLevel: 'BEGINNER',",
          "  hoursPerWeek: '10',",
          "  tinyHoursPerWeek: '1',",
          "  knownTopicsJson: '[]',",
          "  knownTopicsWithJavaBasicsJson: '[\"Java Basics\"]'",
          "};",
          "Object.entries(defaults).forEach(([key, value]) => {",
          "  if (!pm.environment.get(key)) {",
          "    pm.environment.set(key, value);",
          "  }",
          "});",
          "if (!pm.environment.get('registerEmail')) {",
          "  pm.environment.set('registerEmail', `manual.${Date.now()}@example.com`);",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Standard register/login/refresh flow with JWT access and refresh tokens.",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{registerEmail}}\",\n  \"password\": \"{{registerPassword}}\",\n  \"displayName\": \"{{registerDisplayName}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Expected: 201 Created. Saves accessToken and refreshToken into environment."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Tokens are returned', function () {",
                  "  pm.expect(json.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.refreshToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.tokenType).to.eql('Bearer');",
                  "});",
                  "pm.environment.set('accessToken', json.accessToken);",
                  "pm.environment.set('refreshToken', json.refreshToken);"
                ]
              }
            }
          ]
        },
