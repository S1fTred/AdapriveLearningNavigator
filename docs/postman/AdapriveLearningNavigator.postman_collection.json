    {
      "name": "Plan / Live AI",
      "description": "Nondeterministic checks against the live Ollama model.",
      "item": [
        {
          "name": "Generate Plan With AI",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"goal\": \"{{goal}}\",\n  \"currentLevel\": \"{{currentLevel}}\",\n  \"hoursPerWeek\": {{hoursPerWeek}},\n  \"knownTopics\": {{knownTopicsJson}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/plans/generate-with-ai",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "plans",
                "generate-with-ai"
              ]
            },
            "description": "Live AI check. Common outcomes: 200 if the LLM returns a valid route fully mappable to KB, 400 if AI returns unknown topics, 503 if Ollama is unavailable. This request stores planId on 200."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is not 500', function () {",
                  "  pm.expect(pm.response.code).to.not.eql(500);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.environment.set('planId', json.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Generate Plan With Known Topics",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
