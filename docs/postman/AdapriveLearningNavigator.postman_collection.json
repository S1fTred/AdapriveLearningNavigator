        {
          "name": "Generate Plan When Ollama Is Down",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"goal\": \"{{goal}}\",\n  \"currentLevel\": \"{{currentLevel}}\",\n  \"hoursPerWeek\": {{hoursPerWeek}},\n  \"knownTopics\": {{knownTopicsJson}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/plans/generate-with-ai",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "plans",
                "generate-with-ai"
              ]
            },
            "description": "Stop Ollama manually before sending this request. Expected: 503 Service Unavailable."
          },
          "event": [
            {
              "listen": "test",
              "script": {
